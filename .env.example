# =============================================================================
# Shared API key — used by the vLLM server and by the test client.
# Generate a strong key: openssl rand -hex 32
# =============================================================================
VLLM_API_KEY=

# =============================================================================
# Testing (vllm/testing/)
# =============================================================================

# Base URL of the running vLLM stack (no trailing slash, no /v1 path)
API_BASE_URL=http://localhost

# Model name as reported by the vLLM /v1/models endpoint
MODEL=/models/Ministral-3-8B-Instruct-2512

# =============================================================================
# Thermal guard (vllm/thermal-guard/)
# =============================================================================

# Stop the LLM container when any GPU reaches this temperature (°C).
THERMAL_THRESHOLD_C=80

# How often to poll GPU temperatures in seconds.
THERMAL_POLL_SECONDS=5

# Name of the LLM container to stop on overtemp.
LLM_CONTAINER_NAME=vllm
