# Temperature threshold in Celsius.
# The vllm container will be stopped if any GPU reaches this temperature.
THERMAL_THRESHOLD_C=80

# How often to poll GPU temperatures (in seconds).
THERMAL_POLL_SECONDS=5

# Advanced overrides (optional)
# EXPORTER_URL=http://dcgm-exporter:9400/metrics
# CONTAINER_NAME=vllm
# DOCKER_STOP_TIMEOUT=30
