# API key must match the VLLM_API_KEY set in vllm/llm-deployment/.env
VLLM_API_KEY="your-secret-api-key-here"

# Base URL of the vLLM server (no trailing slash).
# Can be a hostname, LAN address, or IP. The script appends /v1/chat/completions.
API_BASE_URL="http://localhost"

# Model identifier passed in the chat completions request body.
# Use the model directory name as it appears inside the container.
MODEL="/models/Ministral-3-3B-Instruct-2512"
# MODEL="/models/Ministral-3-8B-Instruct-2512"
# MODEL="/models/Ministral-3-14B-Instruct-2512"
# MODEL="/models/Devstral-2-123B-Instruct-2512"
# MODEL="/models/gpt-oss-20b"
# MODEL="/models/gpt-oss-120b"
